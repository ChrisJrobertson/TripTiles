# ============================================================================
# TripTiles Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================================================

# --- Supabase ---
# https://supabase.com/dashboard/project/hjbbojypllltfjfuojzn/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://hjbbojypllltfjfuojzn.supabase.co
# Use either legacy anon key or newer publishable key (Dashboard → API):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Live wait times (Queue-Times ingestion; separate from catalogue) ---
# Provider id: queue_times (default). Base URL optional — public JSON endpoints.
LIVE_WAIT_PROVIDER=queue_times
LIVE_WAIT_QUEUE_TIMES_BASE_URL=https://queue-times.com/en-US
# Comma-separated Queue-Times park ids (see parks.json). Defaults to 6,5 (MK + Epcot) if unset.
LIVE_WAIT_QUEUE_TIMES_PARK_IDS=
# Advisory UI horizon: observed_at + N minutes → stale_after on live_wait_current.
LIVE_WAIT_STALE_AFTER_MINUTES=15
# Set to 1 to skip ingestion (Vercel cron + CLI both respect this).
#LIVE_WAIT_INGEST_DISABLED=1
# Comma-separated staff emails allowed to open /internal/live-wait (mapping diagnostics).
#TRIPTILES_INTERNAL_EMAIL_ALLOWLIST=you@example.com
# Vercel Cron sends Authorization: Bearer ${CRON_SECRET} to /api/cron/process-emails and /api/cron/live-wait-ingest.
#CRON_SECRET=

# --- Site ---
# Dev: http://localhost:3001 (this repo runs `npm run dev` on port 3001).
# Prod: https://triptiles.app — no trailing slash.
# In Supabase → Auth → URL configuration, set Site URL to your canonical prod URL and add:
#   http://localhost:3001/auth/callback
#   http://localhost:3001/**
#   https://www.triptiles.app/auth/callback   (and/or apex — match NEXT_PUBLIC_SITE_URL)
#   https://www.triptiles.app/**
# OAuth and legacy /auth/callback routes should match Site URL; set NEXT_PUBLIC_SITE_URL on Vercel to the same host you list above.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Anthropic (Session 5) ---
ANTHROPIC_API_KEY=

# --- Resend (Session 8) ---
RESEND_API_KEY=

# --- Stripe (GBP subscriptions) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Dashboard (Products → each price). Must match src/lib/stripe/products.ts.
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_ANNUAL=
# Coupon id (create customer-facing promotion code LAUNCH50 in Stripe Dashboard)
STRIPE_COUPON_LAUNCH50=acroKjGm

# --- Sentry (error monitoring; optional until you add a project) ---
# Create a Next.js project at sentry.io and paste the DSN. Client needs NEXT_PUBLIC_*.
# For uploaded source maps in production, also set SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT in Vercel.
NEXT_PUBLIC_SENTRY_DSN=
# Optional: server-only DSN if different from public (usually same DSN works for both).
SENTRY_DSN=

# --- Feedback (friends launch) ---
# Shown on /feedback mailto: link (e.g. hello@triptiles.app).
NEXT_PUBLIC_FEEDBACK_EMAIL=

# --- Affiliates (Session 7) ---
NEXT_PUBLIC_BOOKING_COM_AID=
NEXT_PUBLIC_VIATOR_PID=
NEXT_PUBLIC_ATTRACTIONTICKETS_AFFILIATE_ID=
NEXT_PUBLIC_STAYSURE_AFFILIATE_ID=
NEXT_PUBLIC_DISCOVERCARS_AFFILIATE_ID=
