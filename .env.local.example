# ============================================================================
# TripTiles Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ============================================================================

# --- Supabase ---
# https://supabase.com/dashboard/project/hjbbojypllltfjfuojzn/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://hjbbojypllltfjfuojzn.supabase.co
# Use either legacy anon key or newer publishable key (Dashboard → API):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Site ---
# Dev: http://localhost:3001 (this repo runs `npm run dev` on port 3001).
# Prod: https://triptiles.app — no trailing slash.
# In Supabase → Auth → URL configuration, set Site URL to your canonical prod URL and add:
#   http://localhost:3001/auth/callback
#   http://localhost:3001/**
#   https://www.triptiles.app/auth/callback   (and/or apex — match NEXT_PUBLIC_SITE_URL)
#   https://www.triptiles.app/**
# Magic links use NEXT_PUBLIC_SITE_URL for emailRedirectTo — set it on Vercel to the same host you list above.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Anthropic (Session 5) ---
ANTHROPIC_API_KEY=

# --- Resend (Session 8) ---
RESEND_API_KEY=

# --- Payhip (checkout + webhooks) ---
# Paste each product’s checkout/buy link from your Payhip dashboard.
# Pricing page + upgrade modal use PRO; Family/Premium are optional tiers.
NEXT_PUBLIC_PAYHIP_PRO_URL=
NEXT_PUBLIC_PAYHIP_FAMILY_URL=
NEXT_PUBLIC_PAYHIP_PREMIUM_URL=
# Payhip Settings → Developer: API key. Used to verify webhook `signature`
# (see Payhip webhook docs). Webhook URL (production):
#   {NEXT_PUBLIC_SITE_URL}/api/webhooks/payhip
# You still need to map paid events → profiles.tier in that route handler.
PAYHIP_WEBHOOK_SECRET=

# --- Feedback (friends launch) ---
# Shown on /feedback mailto: link (e.g. hello@triptiles.com).
NEXT_PUBLIC_FEEDBACK_EMAIL=

# --- Affiliates (Session 7) ---
NEXT_PUBLIC_BOOKING_COM_AID=
NEXT_PUBLIC_VIATOR_PID=
NEXT_PUBLIC_ATTRACTIONTICKETS_AFFILIATE_ID=
NEXT_PUBLIC_STAYSURE_AFFILIATE_ID=
NEXT_PUBLIC_DISCOVERCARS_AFFILIATE_ID=
