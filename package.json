{
  "name": "triptiles",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "dev:clean": "rm -rf .next && next dev --turbopack -p 3001",
    "build": "next build --turbopack",
    "catalogue:extract": "tsx scripts/extract-catalogue.ts",
    "catalogue:import": "tsx scripts/import-catalogue.ts",
    "start": "next start",
    "lint": "eslint",
    "smoke": "node --env-file=.env.local --import tsx scripts/smoke-test-supabase.ts",
    "preflight": "node --env-file=.env.local --import tsx scripts/preflight-launch-check.ts",
    "content-quality": "node --import tsx scripts/content-quality-guard.ts",
    "report:alignment": "node --env-file=.env.local --import tsx scripts/report-park-alignment.ts",
    "import:alignment": "node --env-file=.env.local --import tsx scripts/import/alignment-import.ts",
    "backfill:alignment-safe": "node --env-file=.env.local --import tsx scripts/safe-backfill-park-alignment.ts",
    "verify:orlando-baseline": "node --env-file=.env.local --import tsx scripts/verify-orlando-catalogue-baseline.ts",
    "verify:florida-baseline": "node --env-file=.env.local --import tsx scripts/verify-florida-catalogue-baseline.ts",
    "verify:profiles-schema": "node scripts/verify-profiles-columns.mjs",
    "verify:smart-plan-cruise": "npx tsx scripts/verify-smart-plan-cruise-filter.ts",
    "live-wait:ingest": "node --import tsx scripts/live-wait-ingest.ts",
    "live-wait:ingest:dry": "node --import tsx scripts/live-wait-ingest.ts --dry-run",
    "test": "npx tsx src/lib/skip-line-clashes.test.ts && npx tsx src/lib/ai-sanitize-notes.test.ts && npx tsx src/lib/region-skip-line-ui.test.ts && npx tsx src/lib/ai/region-briefing.test.ts && npx tsx src/lib/data-import/import-validation.test.ts",
    "test:skip-line-clashes": "npx tsx src/lib/skip-line-clashes.test.ts",
    "deploy:vercel": "vercel --prod --yes"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.87.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-pdf/renderer": "^4.4.1",
    "@sentry/nextjs": "^10.52.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.10.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
